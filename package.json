{
    "name": "conna",
    "version": "1.0.0",
    "description": "Conna App",
    "main": "dist/index.html",
    "packageManager": "bun@1.1.42",
    "sciterVersion": "5.0.3.21",
    "scripts": {
        "install-sdk": "bun run ./scripts/install.mjs cleanup",
        "sdk-version": "bun run ./scripts/version.mjs",
        "scapp": "bun run ./scripts/start.mjs scapp",
        "usciter": "bun run ./scripts/start.mjs usciter",
        "stop": "bun run ./scripts/stop.mjs",
        "scapp32": "bun run ./scripts/start.mjs scapp32",
        "usciter32": "bun run ./scripts/start.mjs usciter32",
        "sciter-build": "bun run ./scripts/build.mjs",
        "$$separator1$$": "echo 'why?'",
        "build": "rspack build",
        "watch": "rspack build --watch"
    },
    "dependencies": {
        "preact": "^10.25.4"
    },
    "devDependencies": {
        "@rspack/cli": "^1.1.8",
        "@rspack/core": "^1.1.8",
        "css-loader": "^7.1.2",
        "download": "^8.0.0",
        "fkill": "^9.0.0",
        "prettier": "^3.4.2",
        "sciter-logger": "^1.1.7",
        "sciter-utils": "^1.0.8",
        "ts-node": "^10.9.2"
    },
    "resolve": {
        "alias": {
            "react": "preact/compat",
            "react-dom/test-utils": "preact/test-utils",
            "react-dom": "preact/compat",
            "react/jsx-runtime": "preact/jsx-runtime"
        }
    }
}
