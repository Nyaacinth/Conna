{
    "$schema": "https://biomejs.dev/schemas/1.4.1/schema.json",
    "files": {
        "ignoreUnknown": true,
        "ignore": ["node_modules/**/*", "dist/**/*", "src-tauri/**/*"]
    },
    "organizeImports": {
        "enabled": true
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "useExhaustiveDependencies": "warn",
                "useHookAtTopLevel": "warn"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "lineWidth": 120,
        "indentWidth": 4,
        "indentStyle": "space",
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "semicolons": "asNeeded",
            "quoteStyle": "double",
            "jsxQuoteStyle": "double",
            "quoteProperties": "asNeeded",
            "trailingComma": "none",
            "bracketSpacing": true,
            "bracketSameLine": false,
            "arrowParentheses": "always"
        }
    }
}
